# Copy to .env and fill in. Never commit .env.

# App
ENV=dev                                    # dev | staging | prod
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173         # comma-separated, no default in prod
TEMPLATE_EXAMPLE=1                         # flip to 0 after `make clean-example`

# Database
# Local dev via docker-compose:
DATABASE_URL=postgresql+asyncpg://starter_owner:starter_dev_password_change_me@localhost:5432/starter
# Or Supabase pooler (transaction mode, port 6543). Requires statement_cache_size=0:
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# App's runtime Postgres role — the role that JWT claims are injected for.
# NEVER set this to a superuser or a service-role DSN. RLS depends on this.
APP_DB_ROLE=authenticated

# Supabase Auth (JWT issuer)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
# NOTE: service-role key intentionally absent. See docs/admin-scripts.md.

# Frontend origin used for JWT `aud` validation. Supabase default is "authenticated".
JWT_AUD=authenticated
JWT_LEEWAY_SECONDS=30

# Rate limiting (slowapi)
RATE_LIMIT_DEFAULT=60/minute

# Observability
STRUCTLOG_JSON=1
LOG_REQUEST_BODIES=0                       # never enable in prod; PII leak vector
